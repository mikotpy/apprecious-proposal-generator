# ============================================================
# Apprecious Proposal Generator — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# ── Claude (Anthropic) API ──────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth2 ────────────────────────────────────────────
# Create at: Google Cloud Console > APIs & Services > Credentials
# Application type: Desktop App
# Add http://localhost:3001 as an Authorised Redirect URI
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Run  node auth-setup.js  once to generate this automatically
GOOGLE_REFRESH_TOKEN=

# ── Google Drive & Sheets ────────────────────────────────────
# The ID of the Google Drive folder where proposals will be saved
# (from the folder URL: drive.google.com/drive/folders/THIS_ID_HERE)
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUv

# The ID of the Google Sheet used to log all leads
# (from the sheet URL: docs.google.com/spreadsheets/d/THIS_ID_HERE/edit)
GOOGLE_SHEETS_ID=1AbCdEfGhIjKlMnOpQrStUv

# ── Server ───────────────────────────────────────────────────
PORT=3000
